{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/real_hook_probe.py\"",
            "timeout": 30,
            "statusMessage": "006a probe: checking submitted prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/real_hook_probe.py\"",
            "timeout": 30,
            "statusMessage": "006a probe: checking tool use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/real_hook_probe.py\"",
            "timeout": 30,
            "statusMessage": "006a probe: checking stop condition"
          }
        ]
      }
    ]
  }
}
